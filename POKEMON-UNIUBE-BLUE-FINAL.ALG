         escreval("::::::::::::::::::::::::::::::::: ##:::: ##: ##:::: ##: ##::::::: ######:::::: ##::'####:'##:::. ##: ## ## ##: #########: ##:::: ##: ##:::: ##:: ##::::::::::::::::::::::::::::::::::::::::::")
