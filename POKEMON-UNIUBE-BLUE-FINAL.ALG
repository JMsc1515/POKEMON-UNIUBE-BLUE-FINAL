      escreval("  >> ROCK TUNNEL")
      escreval("=============================================================================================================================================================================================")
      escreval("  Sem luz. Apenas a escuridao e o eco dos seus passos.")
      escreval("  As paredes sao de granito puro, frias ao toque.")
      escreval("  O chao range sob pedras soltas e minerios.")
      escreval("")
      escreval("  Este lugar e territorio dos Pokemon de rocha e luta.")
      escreval("  Onix pode ser visto rastejando pelas paredes de pedra...")
      escreval("=============================================================================================================================================================================================")
      pausar()
      limpatela
   fimse
   se area = 5 entao
      limpatela
      timer(35)
