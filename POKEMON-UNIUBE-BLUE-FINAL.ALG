// ============================================================
//  MENU POKEMON
// ============================================================
procedimento menuPokemon()
inicio
   desenharTela()
   escreval("  SEU TIME:")
   escreval("---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------")
   para p de 1 ate tamTime faca
      se ativoJog[p] entao
         escreva("  [", p, "] ", nomeJog[p], "  ")
         desenharHPGrande(hpJog[p], hpMaxJog[p], falso)
         escreval("  HP: ", hpJog[p], "/", hpMaxJog[p])
      senao
         escreval("---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------")
      fimse
   fimpara
   escreval("  [0] Voltar")
   escreval("---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------")
   escreva("  Escolha: ")
fimprocedimento

