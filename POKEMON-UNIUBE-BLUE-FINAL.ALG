         escreval("%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%==========+++=:-++++=-.-+++-:-==-:::==++++++++++==:::-%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%  ")
