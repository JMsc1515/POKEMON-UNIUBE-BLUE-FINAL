procedimento carregarRival3()
// Rival 3: starter 2x evoluido + Pidgeot + Kadabra
inicio
   tamTimeIni <- 3
   ativoIni[1] <- verdadeiro
   ativoIni[2] <- verdadeiro
   ativoIni[3] <- verdadeiro
   se starterIdx = 1 entao
      nomeIni[1]       <- "CHARIZARD"
