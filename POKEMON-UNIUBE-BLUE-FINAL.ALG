// ============================================================
// ============================================================
//  INICIO DO PROGRAMA
// ============================================================
// ============================================================
inicio
   // -------------------------------------------------------
   //  TELA INICIAL
   // -------------------------------------------------------
   acao <- 0
   enquanto (acao <> 1) e (acao <> 3) faca
      telaIntro()
      leia(acao)
      se acao = 2 entao
         telaTutorial()
         acao <- 0
      fimse
   fimenquanto

   se acao = 3 entao
      limpatela
       escreval("      ")
