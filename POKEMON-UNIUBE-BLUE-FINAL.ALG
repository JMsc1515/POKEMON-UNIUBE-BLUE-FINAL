//  TELA DE COMBATE
// ============================================================

procedimento desenharTela()
inicio
   limpatela
   escreval("=============================================================================================================================================================================================")
   escreval(" ", nomeIni[atualIni], "")
   desenharHPGrande(hpIni[atualIni], hpMaxIni[atualIni], verdadeiro)
   escreval(" HP: ", hpIni[atualIni], " / ", hpMaxIni[atualIni])
   escreval("---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------")
   escreval(" ", nomeJog[atualJog], "")
   desenharHPGrande(hpJog[atualJog], hpMaxJog[atualJog], falso)
   escreval(" HP: ", hpJog[atualJog], " / ", hpMaxJog[atualJog])
   escreval("=============================================================================================================================================================================================")
fimprocedimento
// ============================================================
//  PAUSAR
// ============================================================
procedimento pausar()
inicio
   escreval("  [ ENTER para continuar... ]")
   leia(pausarVar)
fimprocedimento

// ============================================================
//  EXIBIR MENSAGEM
// ============================================================
procedimento exibirMensagem(msg : caractere)
inicio
   desenharTela()
   escreval("  >> ", msg)
   pausar()
fimprocedimento

// ============================================================
//  MENU PRINCIPAL DE BATALHA
// ============================================================
procedimento menuPrincipal()
inicio
   desenharTela()
   escreval("  O que ", nomeJog[atualJog], " vai fazer?")
   escreval("---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------")
   escreval("  1 - LUTA")
   escreval("  2 - MOCHILA")
   escreval("  3 - POKEMON")
   escreval("  4 - FUGIR")
   se (hpIni[atualIni] <= (hpMaxIni[atualIni] div 2)) e (tamTime < 6) e (tentCaptura < 3) e ehSelvagem entao
      escreval("  5 - POKEBOLA  (HP baixo! Hora de capturar!)")
   fimse
   escreval("---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------")
   escreva("  Escolha: ")
fimprocedimento

// ============================================================
//  MENU LUTA
// ============================================================
procedimento menuLuta()
inicio
   desenharTela()
   escreval("  Escolha o ataque:")
   escreval("---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------")
   escreval("  1 - ", nomeAtkJog[atualJog, 1], "  (poder: ", danoAtkJog[atualJog, 1], ")")
   escreval("  2 - ", nomeAtkJog[atualJog, 2], "  (poder: ", danoAtkJog[atualJog, 2], ")")
   escreval("  3 - ", nomeAtkJog[atualJog, 3], "  (poder: ", danoAtkJog[atualJog, 3], ")")
   escreval("  4 - ", nomeAtkJog[atualJog, 4], "  (poder: ", danoAtkJog[atualJog, 4], ")")
   escreval("  0 - Voltar")
   escreval("---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------")
   escreva("  Escolha: ")
fimprocedimento

