         escreval("::::::::::::::::::::::::::::::::::. ## ##::: ##:::: ##: ##::: ##: ##:::::::::: ##::: ##:: ##.... ##: ##:. ###: ##:::: ##: ##:::: ##: ##:::: ##:'####:::::::::::::::::::::::::::::::::::::::::")
         escreval(":::::::::::::::::::::::::::::::::::. ###::::. #######::. ######:: ########::::. ######::: ##:::: ##: ##::. ##: ##:::: ##:. #######::. #######:: ####:::::::::::::::::::::::::::::::::::::::::")
         escreval("::::::::::::::::::::::::::::::::::::...::::::.......::::......:::........::::::......::::..:::::..::..::::..::..:::::..:::.......::::.......:::....::::::::::::::::::::::::::::::::::::::::::")
         escreval("=============================================================================================================================================================================================")
