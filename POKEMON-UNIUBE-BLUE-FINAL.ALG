// ============================================================
// ============================================================
//  GERADOR DE POKEMON SELVAGEM POR AREA
// ============================================================
// ============================================================

procedimento gerarSelvagem(area : inteiro)
var
   sorteio : inteiro
inicio
   se area = 1 entao
      // VIRIDIAN FOREST: Caterpie, Weedle, Pidgey, Rattata, Pikachu
      sorteio <- randi(5) + 1
      se sorteio = 1 entao
         carregarCaterpie()
      fimse
      se sorteio = 2 entao
         carregarWeedle()
      fimse
      se sorteio = 3 entao
         carregarPidgey()
      fimse
      se sorteio = 4 entao
         carregarRattata()
      fimse
      se sorteio = 5 entao
         carregarPikachu()
      fimse
   fimse
   se area = 2 entao
      // MT. MOON: Zubat, Geodude, Clefairy, Paras, Sandshrew
      sorteio <- randi(5) + 1
      se sorteio = 1 entao
         carregarZubat()
      fimse
      se sorteio = 2 entao
         carregarGeodude()
      fimse
      se sorteio = 3 entao
         carregarClefairy()
      fimse
      se sorteio = 4 entao
         carregarParas()
      fimse
      se sorteio = 5 entao
         carregarSandshrew()
      fimse
   fimse
   se area = 3 entao
      // CERULEAN: Psyduck, Poliwag, Magikarp, Tentacool
      sorteio <- randi(4) + 1
      se sorteio = 1 entao
         carregarPsyduck()
      fimse
      se sorteio = 2 entao
         carregarPoliwag()
      fimse
      se sorteio = 3 entao
         carregarMagikarp()
      fimse
      se sorteio = 4 entao
         carregarTentacool()
      fimse
   fimse
   se area = 4 entao
      // ROCK TUNNEL: Geodude, Onix, Machop, Graveler(usa Geodude stats+)
      sorteio <- randi(4) + 1
      se sorteio = 1 entao
         carregarGeodude()
      fimse
      se sorteio = 2 entao
         carregarOnix()
      fimse
      se sorteio = 3 entao
         carregarMachop()
      fimse
      se sorteio = 4 entao
         // GRAVELER (versao mais forte de Geodude)
         nomeIni[1]       <- "GRAVELER"
         hpMaxIni[1]      <- 55
         hpIni[1]         <- 55
         nomeAtkIni[1,1]  <- "Rock Throw"
         danoAtkIni[1,1] <- 18
         nomeAtkIni[1,2]  <- "Magnitude"
         danoAtkIni[1,2] <- 22
         nomeAtkIni[1,3]  <- "Earthquake"
         danoAtkIni[1,3] <- 28
         nomeAtkIni[1,4]  <- "Explosion"
         danoAtkIni[1,4] <- 32
         limpatela
         timer(20)
         escreval("%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% ")
         escreval("%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%  ")
         escreval("%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%  ")
         escreval("%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%#***#%%%%%%%%%%%%%%%%%%%  ")
         escreval("%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%++===+%#=====*%%%%%%%*++==*%%%%%%%%%%%%%%%%%%%%%%*=+###*+=+#%%%%%%%%%%%%%%%  ")
         escreval("%%%%%%%*+========+*%%%%%%%%%%%%%%%%%%%%%%%%****+=::=+++++++=======****++=#%%%%%%%%%%%%%%%%%%%%*:=####*+++*#%%%%%%%%%%%%%  ")
         escreval("%%%*****++++=-=+++++##*++++*#%%%%%%%%%%%%****###*=-:-*****+===--=+*###*++==++++#%%%%%%%%%%%%%%#+==+###**+++*#%%%%%%%%%%%  ")
         escreval("%***********+-+***+=+*++++=++*#%%%%%%%%****#######+.-*****++++++*####**+=--====+*#%%%%%%%%%%%%%%*==+*#***+-=#%%%%%%%%%%% ")
         escreval("%==####**++===+****+==*###*+==*%%%%%%%%-:#########*-=*****+++*######*++-:+*****==*#%%%%%%%%####%%%+.-++**=-=*###%%%%%%%%  ")
         escreval("%::*****+.:--++++++=--*##*+++=-*%%%%%%%::**##########******+**######*-:+*********--#%%%%%#*---+###+..:-==+*+=--+##%%%%%%  ")
         escreval("%%%......--++++++++=::=*+++++=:*%%%%%%%%%..##########****************************:.#%%%%*.-###*-:.-+++++++*****+-+#%%%%%  ")
         escreval("%%%%%%%%#--++++++++++=:......:*%%%%%%%%----####+=---=*********++++***************:.:-%%%*.-####***+-=++++=---=*+-+#%%%%%  ")
