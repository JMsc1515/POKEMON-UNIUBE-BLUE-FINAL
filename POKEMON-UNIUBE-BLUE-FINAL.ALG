         escreval("%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%  ")
         escreval("%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% ")

      fimse
   fimse
   se area = 5 entao
      // LAVENDER TOWN: Gastly, Haunter, Cubone, Drowzee
      sorteio <- randi(4) + 1
      se sorteio = 1 entao
         carregarGastly()
      fimse
      se sorteio = 2 entao
         carregarHaunter()
      fimse
