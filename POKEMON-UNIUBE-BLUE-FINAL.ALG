// ============================================================
//BARRA DE HP
procedimento desenharHPGrande(hpAtual, hpMax : inteiro; ehInimigo : logico)
var
   cheios, i, linha : inteiro
   linhaTexto : vetor[1..10] de caractere
inicio
   cheios <- (hpAtual * 5) div hpMax

   para linha de 1 ate 10 faca
      linhaTexto[linha] <- ""
   fimpara

   para i de 1 ate 5 faca
      se i <= cheios entao
         escreval("")
         linhaTexto[1]  <- linhaTexto[1]  + "  @@@@ @@@@    "
         linhaTexto[2]  <- linhaTexto[2]  + " @@@@@@@@@@@   "
         linhaTexto[3]  <- linhaTexto[3]  + " @@@@@@@@@@@   "
         linhaTexto[4]  <- linhaTexto[4]  + " @@@@@@@@@@@   "
         linhaTexto[5]  <- linhaTexto[5]  + "  @@@@@@@@@    "
         linhaTexto[6]  <- linhaTexto[6]  + "   @@@@@@@     "
         linhaTexto[7]  <- linhaTexto[7]  + "    @@@@@      "
         linhaTexto[8]  <- linhaTexto[8]  + "     @@@       "
         linhaTexto[9]  <- linhaTexto[9]  + "      @        "
         linhaTexto[10] <- linhaTexto[10] + "               "
      senao
         escreval("")
         linhaTexto[1]  <- linhaTexto[1]  + "  .... ....    "
         linhaTexto[2]  <- linhaTexto[2]  + " ...........   "
         linhaTexto[3]  <- linhaTexto[3]  + " ...........   "
         linhaTexto[4]  <- linhaTexto[4]  + " ...........   "
         linhaTexto[5]  <- linhaTexto[5]  + "  .........    "
         linhaTexto[6]  <- linhaTexto[6]  + "   .......     "
         linhaTexto[7]  <- linhaTexto[7]  + "    .....      "
         linhaTexto[8]  <- linhaTexto[8]  + "     ...       "
         linhaTexto[9]  <- linhaTexto[9]  + "      .        "
         linhaTexto[10] <- linhaTexto[10] + "               "
      fimse
   fimpara

   para linha de 1 ate 10 faca
      escreval(linhaTexto[linha])
   fimpara
fimprocedimento

