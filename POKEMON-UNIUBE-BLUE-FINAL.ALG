// ============================================================
//  VERIFICAR TIME JOGADOR
// ============================================================
procedimento verificarTimeJogador()
var
   iTemp     : inteiro
   algumVivo : logico
inicio
   algumVivo <- falso
   para iTemp de 1 ate tamTime faca
      se ativoJog[iTemp] entao
         algumVivo <- verdadeiro
      fimse
   fimpara
   se nao algumVivo entao
      desenharTela()

      escreval("                                                                              Todos os seus Pokemon desmaiaram!")
      escreval("")
      escreval("")
      escreval("=============================================================================================================================================================================================")
      escreval(":::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::")
