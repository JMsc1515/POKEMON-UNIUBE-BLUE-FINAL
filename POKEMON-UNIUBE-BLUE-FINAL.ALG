      escreval("")
      escreval("")
      escreval("==============================================================================================================================================================================================")
      escreval("  Um ", nomeIni[1], " selvagem apareceu!")
      escreval("  VAI, ", nomeJog[atualJog], "!")
      escreval("==============================================================================================================================================================================================")
      pausar()
      iniciarBatalha(1)
      loopBatalha()

      para i de 1 ate tamTime faca
         hpJog[i] <- hpMaxJog[i]
         ativoJog[i] <- verdadeiro
      fimpara

      // -------------------------------------------------------
      //  RIVAL 3 - BATALHA FINAL
      // -------------------------------------------------------
      cutsceneRival3()
      carregarRival3()
      iniciarBatalhaRival(3)
      loopBatalha()
      // -------------------------------------------------------
      //  FIM DO JOGO
      // -------------------------------------------------------
      podeTrocar <- falso
      para i de 1 ate tamTime faca
         se ativoJog[i] entao
            podeTrocar <- verdadeiro
         fimse
      fimpara
      cutsceneFim(podeTrocar)
   fimse
fimalgoritmo

