procedimento verificarTimeInimigo()
var
   iTemp : inteiro
inicio
   se hpIni[atualIni] < 0 entao
      hpIni[atualIni] <- 0
   fimse
   se hpIni[atualIni] = 0 entao
      ativoIni[atualIni] <- falso
      exibirMensagem(nomeIni[atualIni] + " desmaiou!")
      cenaDerrota(nomeIni[atualIni])
      todosVivos <- falso
      para iTemp de 1 ate tamTimeIni faca
         se ativoIni[iTemp] e (nao todosVivos) entao
            todosVivos <- verdadeiro
            atualIni <- iTemp
         fimse
      fimpara
      se todosVivos entao
         exibirMensagem(nomeRival + " enviou " + nomeIni[atualIni] + "!")
      senao
         desenharTela()

         escreval("")
         escreval("                                                                                  Time inimigo derrotado!")
         escreval("")
         escreval("")
         escreval("=============================================================================================================================================================================================")
         escreval(":::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::")
         escreval("::::::::::::::::::::::::::::::::: ##::::'##::'#######:::'######::'########:::::'######::::::'###::::'##::: ##:'##::::'##::'#######::'##::::'##:'####:::::::::::::::::::::::::::::::::::::::::")
