procedimento carregarSquirtle(slot : inteiro)
inicio
   nomeJog[slot]       <- "SQUIRTLE"
   hpMaxJog[slot]      <- 44
   hpJog[slot]         <- 44
   ativoJog[slot]      <- verdadeiro
   nomeAtkJog[slot,1]  <- "Water Gun"
   danoAtkJog[slot,1] <- 13
   nomeAtkJog[slot,2]  <- "Bite"
   danoAtkJog[slot,2] <- 14
   nomeAtkJog[slot,3]  <- "Surf"
   danoAtkJog[slot,3] <- 22
   nomeAtkJog[slot,4]  <- "Ice Beam"
   danoAtkJog[slot,4] <- 24
   limpatela
