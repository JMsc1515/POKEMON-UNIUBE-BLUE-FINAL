algoritmo "POKEMON-UNIUBE-BLUE"
// Disciplina   : Algotimo e Estrutura de Dados
// Professor   : Maxwell Gomes da Silva


var
   // -------------------------------------------------------
   // DADOS DO JOGADOR (time de ate 6 pokemon)
   // -------------------------------------------------------
   nomeJog       : vetor[1..6] de caractere
   hpJog         : vetor[1..6] de inteiro
   hpMaxJog      : vetor[1..6] de inteiro
   ativoJog      : vetor[1..6] de logico

   nomeAtkJog    : vetor[1..6, 1..4] de caractere
   danoAtkJog    : vetor[1..6, 1..4] de inteiro

   // -------------------------------------------------------
   // DADOS DO INIMIGO (rival tem ate 3; selvagem tem 1)
   // -------------------------------------------------------
   nomeIni       : vetor[1..3] de caractere
   hpIni         : vetor[1..3] de inteiro
   hpMaxIni      : vetor[1..3] de inteiro
   ativoIni      : vetor[1..3] de logico


   nomeAtkIni    : vetor[1..3, 1..4] de caractere
   danoAtkIni    : vetor[1..3, 1..4] de inteiro

   // -------------------------------------------------------
   // CONTROLE DE JOGO
   // -------------------------------------------------------
   atualJog      : inteiro
   atualIni      : inteiro
   acao          : inteiro
   dano          : inteiro
   cura          : inteiro
   turno         : inteiro
   batalhaAtiva  : logico



   todosVivos    : logico
   i             : inteiro
   k             : inteiro
   l             : inteiro
   p             : inteiro
   pausarVar     : caractere

   // -------------------------------------------------------
   // NOVOS: NARRATIVA E JORNADA
   // -------------------------------------------------------
   nomePlayer    : caractere
   nomeRival     : caractere
   numJogador    : inteiro
   nomeJog1      : caractere
   nomeJog2      : caractere
   starterIdx    : inteiro
   tamTime       : inteiro
   tamTimeIni    : inteiro
   numRivalBat   : inteiro

   // -------------------------------------------------------
   // CAPTURA
   // -------------------------------------------------------
   tentCaptura   : inteiro
   pkCapturado   : logico
   sorteioA      : inteiro
   sorteioB      : inteiro
   podeTrocar    : logico
   qtdPotion         : inteiro
   qtdSuperPotion    : inteiro

   // -------------------------------------------------------
   // EVOLUCAO DO STARTER
   // -------------------------------------------------------
   batalhasSelvagens : inteiro
   starterEvoluido   : inteiro

   // -------------------------------------------------------
   // CONTROLE DE TIPO DE BATALHA
   // -------------------------------------------------------
   ehSelvagem        : logico

   // -------------------------------------------------------
   // TIPO - SISTEMA DE VANTAGEM
   // -------------------------------------------------------
   tipoAtkAtual      : caractere
   tipoDefAtual      : caractere
   multTipo          : inteiro



