// ============================================================
//  LOOP DE BATALHA PRINCIPAL
// ============================================================
procedimento loopBatalha()
inicio
   enquanto batalhaAtiva faca
      menuPrincipal()
      leia(acao)
      escolha acao
      caso 1
         executarLuta()
      caso 2
         executarMochila()
      caso 3
         executarPokemon()
      caso 4
         exibirMensagem("Nao da para fugir desta batalha!")
      caso 5
         se (hpIni[atualIni] <= (hpMaxIni[atualIni] div 2)) e (tamTime < 6) e (tentCaptura < 3) e ehSelvagem entao
            tentarCaptura()
         senao
            exibirMensagem("Opcao indisponivel agora.")
         fimse
      outrocaso
         exibirMensagem("Opcao invalida!")
      fimescolha
      turno <- turno + 1
   fimenquanto
fimprocedimento

// ============================================================
//  INICIALIZAR BATALHA (reseta estado)
// ============================================================
procedimento iniciarBatalha(numInimigos : inteiro)
inicio
   atualJog     <- 1
   atualIni     <- 1
   turno        <- 1
   batalhaAtiva <- verdadeiro
   tentCaptura  <- 0
   pkCapturado  <- falso
   tamTimeIni   <- numInimigos
   ehSelvagem   <- verdadeiro
   para i de 1 ate numInimigos faca
      ativoIni[i] <- verdadeiro
   fimpara
   // garante que o primeiro pokemon vivo do jogador entra em campo
   atualJog <- 1
   enquanto (atualJog <= tamTime) e (nao ativoJog[atualJog]) faca
      atualJog <- atualJog + 1
   fimenquanto
fimprocedimento

procedimento iniciarBatalhaRival(numInimigos : inteiro)
inicio
   atualJog     <- 1
   atualIni     <- 1
   turno        <- 1
   batalhaAtiva <- verdadeiro
   tentCaptura  <- 0
   pkCapturado  <- falso
   tamTimeIni   <- numInimigos
   ehSelvagem   <- falso
   para i de 1 ate numInimigos faca
      ativoIni[i] <- verdadeiro
   fimpara
   atualJog <- 1
   enquanto (atualJog <= tamTime) e (nao ativoJog[atualJog]) faca
      atualJog <- atualJog + 1
   fimenquanto
fimprocedimento


// ============================================================
//  DADOS DOS POKEMON SELVAGENS
// ============================================================
// ============================================================
//  CALCULA MULTIPLICADOR DE TIPO
//  tipoAtkAtual = tipo do ataque
//  tipoDefAtual = tipo do defensor
//  Resultado em multTipo: 2=super-efetivo, 0=pouco efetivo, 1=normal, -1=imune
// ============================================================

 procedimento calcularMultiplicador()
inicio
   multTipo <- 1

   se tipoAtkAtual = "Fire" entao
      se (tipoDefAtual = "Grass") ou (tipoDefAtual = "Ice") ou (tipoDefAtual = "Bug") ou (tipoDefAtual = "Steel") entao
         multTipo <- 2
      fimse
      se (tipoDefAtual = "Water") ou (tipoDefAtual = "Fire") ou (tipoDefAtual = "Rock") ou (tipoDefAtual = "Dragon") entao
         multTipo <- 0
      fimse
   fimse

   se tipoAtkAtual = "Water" entao
      se (tipoDefAtual = "Fire") ou (tipoDefAtual = "Rock") ou (tipoDefAtual = "Ground") entao
         multTipo <- 2
      fimse
      se (tipoDefAtual = "Water") ou (tipoDefAtual = "Grass") ou (tipoDefAtual = "Dragon") entao
         multTipo <- 0
      fimse
   fimse

   se tipoAtkAtual = "Grass" entao
      se (tipoDefAtual = "Water") ou (tipoDefAtual = "Rock") ou (tipoDefAtual = "Ground") entao
         multTipo <- 2
      fimse
      se (tipoDefAtual = "Fire") ou (tipoDefAtual = "Grass") ou (tipoDefAtual = "Poison") ou (tipoDefAtual = "Flying") ou (tipoDefAtual = "Bug") ou (tipoDefAtual = "Dragon") entao
         multTipo <- 0
      fimse
   fimse

   se tipoAtkAtual = "Electric" entao
      se (tipoDefAtual = "Water") ou (tipoDefAtual = "Flying") entao
         multTipo <- 2
      fimse
      se tipoDefAtual = "Ground" entao
         multTipo <- -1
      fimse
      se (tipoDefAtual = "Electric") ou (tipoDefAtual = "Grass") ou (tipoDefAtual = "Dragon") entao
         multTipo <- 0
      fimse
   fimse

   se tipoAtkAtual = "Rock" entao
      se (tipoDefAtual = "Fire") ou (tipoDefAtual = "Flying") ou (tipoDefAtual = "Bug") ou (tipoDefAtual = "Ice") entao
         multTipo <- 2
      fimse
      se (tipoDefAtual = "Rock") ou (tipoDefAtual = "Ground") ou (tipoDefAtual = "Fighting") entao
         multTipo <- 0
      fimse
   fimse

   se tipoAtkAtual = "Ground" entao
      se (tipoDefAtual = "Fire") ou (tipoDefAtual = "Electric") ou (tipoDefAtual = "Rock") ou (tipoDefAtual = "Poison") ou (tipoDefAtual = "Steel") entao
         multTipo <- 2
      fimse
      se tipoDefAtual = "Flying" entao
         multTipo <- -1
      fimse
      se (tipoDefAtual = "Grass") ou (tipoDefAtual = "Bug") entao
         multTipo <- 0
      fimse
   fimse

   se tipoAtkAtual = "Flying" entao
      se (tipoDefAtual = "Grass") ou (tipoDefAtual = "Fighting") ou (tipoDefAtual = "Bug") entao
         multTipo <- 2
      fimse
      se (tipoDefAtual = "Rock") ou (tipoDefAtual = "Electric") ou (tipoDefAtual = "Steel") entao
         multTipo <- 0
      fimse
   fimse

   se tipoAtkAtual = "Psychic" entao
      se (tipoDefAtual = "Fighting") ou (tipoDefAtual = "Poison") entao
         multTipo <- 2
      fimse
      se (tipoDefAtual = "Psychic") ou (tipoDefAtual = "Steel") entao
         multTipo <- 0
      fimse
      se tipoDefAtual = "Dark" entao
         multTipo <- -1
      fimse
   fimse

   se tipoAtkAtual = "Ghost" entao
      se (tipoDefAtual = "Ghost") ou (tipoDefAtual = "Psychic") entao
         multTipo <- 2
      fimse
      se tipoDefAtual = "Normal" entao
         multTipo <- -1
      fimse
      se tipoDefAtual = "Dark" entao
         multTipo <- 0
      fimse
   fimse

   se tipoAtkAtual = "Fighting" entao
      se (tipoDefAtual = "Normal") ou (tipoDefAtual = "Ice") ou (tipoDefAtual = "Rock") ou (tipoDefAtual = "Steel") ou (tipoDefAtual = "Dark") entao
         multTipo <- 2
      fimse
      se (tipoDefAtual = "Poison") ou (tipoDefAtual = "Flying") ou (tipoDefAtual = "Psychic") ou (tipoDefAtual = "Bug") entao
         multTipo <- 0
      fimse
      se tipoDefAtual = "Ghost" entao
         multTipo <- -1
      fimse
   fimse

   se tipoAtkAtual = "Poison" entao
      se (tipoDefAtual = "Grass") ou (tipoDefAtual = "Bug") entao
         multTipo <- 2
      fimse
      se (tipoDefAtual = "Poison") ou (tipoDefAtual = "Ground") ou (tipoDefAtual = "Rock") ou (tipoDefAtual = "Ghost") entao
         multTipo <- 0
      fimse
      se tipoDefAtual = "Steel" entao
         multTipo <- -1
      fimse
   fimse

   se tipoAtkAtual = "Bug" entao
      se (tipoDefAtual = "Grass") ou (tipoDefAtual = "Psychic") ou (tipoDefAtual = "Dark") entao
         multTipo <- 2
      fimse
      se (tipoDefAtual = "Fire") ou (tipoDefAtual = "Fighting") ou (tipoDefAtual = "Flying") ou (tipoDefAtual = "Ghost") ou (tipoDefAtual = "Steel") entao
         multTipo <- 0
      fimse
   fimse

   se tipoAtkAtual = "Ice" entao
      se (tipoDefAtual = "Grass") ou (tipoDefAtual = "Ground") ou (tipoDefAtual = "Flying") ou (tipoDefAtual = "Dragon") entao
         multTipo <- 2
      fimse
      se (tipoDefAtual = "Water") ou (tipoDefAtual = "Ice") ou (tipoDefAtual = "Steel") entao
         multTipo <- 0
      fimse
   fimse

   se tipoAtkAtual = "Normal" entao
      se (tipoDefAtual = "Rock") ou (tipoDefAtual = "Steel") entao
         multTipo <- 0
      fimse
      se tipoDefAtual = "Ghost" entao
         multTipo <- -1
      fimse
   fimse

   se tipoAtkAtual = "Dragon" entao
      se tipoDefAtual = "Dragon" entao
         multTipo <- 2
      fimse
      se tipoDefAtual = "Steel" entao
         multTipo <- 0
      fimse
   fimse

fimprocedimento

