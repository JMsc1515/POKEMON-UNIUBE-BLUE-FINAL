      iniciarBatalhaRival(1)
      loopBatalha()

      se nao batalhaAtiva entao
         // verifica se perdeu (todos desmaiaram) ou ganhou
         podeTrocar <- falso
         para i de 1 ate tamTime faca
            se ativoJog[i] entao
               podeTrocar <- verdadeiro
            fimse
         fimpara
      fimse

      // cura o time entre batalhas
      para i de 1 ate tamTime faca
         hpJog[i] <- hpMaxJog[i]
         ativoJog[i] <- verdadeiro
      fimpara

