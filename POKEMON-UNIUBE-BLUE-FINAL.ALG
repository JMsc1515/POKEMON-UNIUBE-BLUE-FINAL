      escreval("  >> CERULEAN CITY - MARGEM DO RIO")
      escreval("=============================================================================================================================================================================================")
      escreval("  A brisa fresca do rio esfria o ar ao seu redor.")
      escreval("  A agua e cristalina, e sombras se movem no fundo.")
      escreval("  Pescadores observam as margens com olhos atentos.")
      escreval("")
      escreval("  Pokemon aquaticos de todos os tipos nadam por aqui.")
      escreval("  Magikarp e comum, mas quem tem paciencia acha muito mais...")
      escreval("=============================================================================================================================================================================================")
      pausar()
      limpatela
   fimse
   se area = 4 entao
      limpatela
      timer(35)
