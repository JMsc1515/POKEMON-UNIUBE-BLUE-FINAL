// ============================================================
//  TURNO DO INIMIGO
// ============================================================
procedimento turnoInimigo()
var
   atkEscolhido : inteiro
   nomeatk      : caractere
inicio
   se batalhaAtiva entao
      atkEscolhido <- (turno mod 4) + 1
      dano <- danoAtkIni[atualIni, atkEscolhido]
      nomeatk <- nomeAtkIni[atualIni, atkEscolhido]

      // --- TIPO DO ATAQUE INIMIGO ---
      tipoAtkAtual <- "Normal"
      se (nomeatk = "Ember") ou (nomeatk = "Flamethrower") ou (nomeatk = "Fire Spin") ou (nomeatk = "Fire Blast") entao
         tipoAtkAtual <- "Fire"
      fimse
      se (nomeatk = "Water Gun") ou (nomeatk = "Surf") ou (nomeatk = "Bubble") ou (nomeatk = "Bubble Beam") ou (nomeatk = "Hydro Pump") entao
         tipoAtkAtual <- "Water"
      fimse
      se (nomeatk = "Vine Whip") ou (nomeatk = "Razor Leaf") ou (nomeatk = "Solar Beam") ou (nomeatk = "Absorb") ou (nomeatk = "Sleep Powder") ou (nomeatk = "Stun Spore") entao
         tipoAtkAtual <- "Grass"
      fimse
      se (nomeatk = "Thunder Shock") ou (nomeatk = "Thunderbolt") ou (nomeatk = "Thunder") entao
         tipoAtkAtual <- "Electric"
      fimse
      se (nomeatk = "Rock Throw") ou (nomeatk = "Rock Blast") entao
         tipoAtkAtual <- "Rock"
      fimse
      se (nomeatk = "Earthquake") ou (nomeatk = "Magnitude") ou (nomeatk = "Bone Club") ou (nomeatk = "Bonemerang") ou (nomeatk = "Bone Rush") entao
         tipoAtkAtual <- "Ground"
      fimse
      se (nomeatk = "Gust") ou (nomeatk = "Wing Attack") ou (nomeatk = "Aerial Ace") ou (nomeatk = "Air Slash") entao
         tipoAtkAtual <- "Flying"
      fimse
      se (nomeatk = "Confusion") ou (nomeatk = "Psybeam") ou (nomeatk = "Psychic") ou (nomeatk = "Dream Eater") ou (nomeatk = "Future Sight") entao
         tipoAtkAtual <- "Psychic"
      fimse
      se (nomeatk = "Lick") ou (nomeatk = "Night Shade") ou (nomeatk = "Shadow Ball") entao
         tipoAtkAtual <- "Ghost"
      fimse
      se (nomeatk = "Low Kick") ou (nomeatk = "Karate Chop") ou (nomeatk = "Seismic Toss") ou (nomeatk = "Cross Chop") entao
         tipoAtkAtual <- "Fighting"
      fimse
      se (nomeatk = "Poison Sting") ou (nomeatk = "Acid") ou (nomeatk = "Sludge Bomb") ou (nomeatk = "Poison Powder") entao
         tipoAtkAtual <- "Poison"
      fimse
      se (nomeatk = "Leech Life") ou (nomeatk = "String Shot") ou (nomeatk = "Pin Missile") entao
         tipoAtkAtual <- "Bug"
      fimse
      se (nomeatk = "Ice Beam") ou (nomeatk = "Blizzard") entao
         tipoAtkAtual <- "Ice"
      fimse
      se (nomeatk = "Dragon Claw") ou (nomeatk = "Dragon Rage") entao
         tipoAtkAtual <- "Dragon"
      fimse

      // --- TIPO DO DEFENSOR (JOGADOR) ---
      tipoDefAtual <- "Normal"

      // Grass/Poison
      se (nomeJog[atualJog] = "BULBASAUR") ou (nomeJog[atualJog] = "IVYSAUR") ou (nomeJog[atualJog] = "VENUSAUR") entao
         tipoDefAtual <- "Grass"
      fimse
      // Fire (mono)
      se (nomeJog[atualJog] = "CHARMANDER") ou (nomeJog[atualJog] = "CHARMELEON") entao
         tipoDefAtual <- "Fire"
      fimse
      // Fire/Flying — Charizard
      se (nomeJog[atualJog] = "CHARIZARD") entao
         tipoDefAtual <- "Fire"
      fimse
      // Water (mono)
      se (nomeJog[atualJog] = "SQUIRTLE") ou (nomeJog[atualJog] = "WARTORTLE") ou (nomeJog[atualJog] = "BLASTOISE") entao
         tipoDefAtual <- "Water"
      fimse
      // Electric (mono)
      se (nomeJog[atualJog] = "PIKACHU") ou (nomeJog[atualJog] = "RAICHU") entao
         tipoDefAtual <- "Electric"
      fimse
      // Normal/Flying
      se (nomeJog[atualJog] = "PIDGEY") ou (nomeJog[atualJog] = "PIDGEOTTO") ou (nomeJog[atualJog] = "PIDGEOT") entao
         tipoDefAtual <- "Flying"
      fimse
      // ERRO 3 CORRIGIDO — Zubat é Poison/Flying, separado de Pidgey
      se (nomeJog[atualJog] = "ZUBAT") entao
         tipoDefAtual <- "Poison"
      fimse
      // ERRO 2 CORRIGIDO — Geodude/Graveler/Onix săo Rock/Ground, Ground captura imunidade a Electric
      se (nomeJog[atualJog] = "GEODUDE") ou (nomeJog[atualJog] = "GRAVELER") ou (nomeJog[atualJog] = "ONIX") entao
         tipoDefAtual <- "Ground"
      fimse
      // Ground (mono)
      se (nomeJog[atualJog] = "SANDSHREW") ou (nomeJog[atualJog] = "CUBONE") entao
         tipoDefAtual <- "Ground"
      fimse
      // Water (mono)
      se (nomeJog[atualJog] = "PSYDUCK") ou (nomeJog[atualJog] = "POLIWAG") ou (nomeJog[atualJog] = "MAGIKARP") entao
         tipoDefAtual <- "Water"
      fimse
      // Water/Psychic
      se (nomeJog[atualJog] = "STARMIE") entao
         tipoDefAtual <- "Psychic"
      fimse
      // ERRO 1 CORRIGIDO — Tentacool é Water/Poison, Water é o tipo principal
      se (nomeJog[atualJog] = "TENTACOOL") entao
         tipoDefAtual <- "Water"
      fimse
      // Bug (mono)
      se (nomeJog[atualJog] = "CATERPIE") ou (nomeJog[atualJog] = "PARAS") entao
         tipoDefAtual <- "Bug"
      fimse
      // ERRO 5 CORRIGIDO — Weedle é Bug/Poison, separado de Caterpie/Paras
      se (nomeJog[atualJog] = "WEEDLE") entao
         tipoDefAtual <- "Poison"
      fimse
      // ERRO 6 CORRIGIDO — Oddish é Grass/Poison, Poison capta fraqueza a Psychic/Ground
      se (nomeJog[atualJog] = "ODDISH") entao
         tipoDefAtual <- "Poison"
      fimse
      // Fire (mono)
      se (nomeJog[atualJog] = "VULPIX") ou (nomeJog[atualJog] = "GROWLITHE") entao
         tipoDefAtual <- "Fire"
      fimse
      // Fighting (mono)
      se (nomeJog[atualJog] = "MACHOP") entao
         tipoDefAtual <- "Fighting"
      fimse
      // Ghost/Poison
      se (nomeJog[atualJog] = "GASTLY") ou (nomeJog[atualJog] = "HAUNTER") entao
         tipoDefAtual <- "Ghost"
      fimse
      // Psychic (mono)
      se (nomeJog[atualJog] = "DROWZEE") ou (nomeJog[atualJog] = "KADABRA") entao
         tipoDefAtual <- "Psychic"
      fimse
      // Normal (mono)
      se (nomeJog[atualJog] = "EEVEE") ou (nomeJog[atualJog] = "CLEFAIRY") ou (nomeJog[atualJog] = "RATTATA") entao
         tipoDefAtual <- "Normal"
      fimse

      // --- APLICAR MULTIPLICADOR ---
      calcularMultiplicador()
      se multTipo = 4 entao
         dano <- dano * 4
         exibirMensagem(nomeIni[atualIni] + " usou " + nomeatk + "! E extremamente efetivo!")
      fimse
      se multTipo = 2 entao
         dano <- dano * 2
         exibirMensagem(nomeIni[atualIni] + " usou " + nomeatk + "! E super-efetivo!")
      fimse
      se multTipo = 1 entao
         exibirMensagem(nomeIni[atualIni] + " usou " + nomeatk + "!")
      fimse
      se multTipo = 0 entao
         dano <- dano div 2
         exibirMensagem(nomeIni[atualIni] + " usou " + nomeatk + "! Nao e muito efetivo...")
      fimse
      se multTipo = -1 entao
         dano <- dano div 4
         exibirMensagem(nomeIni[atualIni] + " usou " + nomeatk + "! Nao e muito efetivo...")
      fimse
      se multTipo = -2 entao
         dano <- 0
         exibirMensagem(nomeIni[atualIni] + " usou " + nomeatk + "! Nao afeta " + nomeJog[atualJog] + "!")
      fimse

      hpJog[atualJog] <- hpJog[atualJog] - dano
      se hpJog[atualJog] < 0 entao
         hpJog[atualJog] <- 0
      fimse

      se hpJog[atualJog] = 0 entao
         ativoJog[atualJog] <- falso
         exibirMensagem(nomeJog[atualJog] + " desmaiou!")
         cenaDerrota(nomeJog[atualJog])
         verificarTimeJogador()
         se batalhaAtiva entao
            acao <- 0
            enquanto (acao < 1) ou (acao > tamTime) faca
               menuPokemon()
               leia(acao)
               se (acao < 1) ou (acao > tamTime) entao
                  exibirMensagem("Escolha invalida!")
               senao
                  se nao ativoJog[acao] entao
                     exibirMensagem("Esse Pokemon desmaiou!")
                     acao <- 0
                  fimse
               fimse
            fimenquanto
            atualJog <- acao
            exibirMensagem("VAI, " + nomeJog[atualJog] + "!")
         fimse
      fimse
   fimse
fimprocedimento

// ============================================================
//  EXECUTAR LUTA
// ============================================================
procedimento executarLuta()
var
   atkscolhido : inteiro
   nomeatk     : caractere
inicio
   menuLuta()
   leia(atkscolhido)
   se (atkscolhido >= 1) e (atkscolhido <= 4) entao
      dano <- danoAtkJog[atualJog, atkscolhido]
      nomeatk <- nomeAtkJog[atualJog, atkscolhido]

      // --- TIPO DO ATAQUE ---
      tipoAtkAtual <- "Normal"
      se (nomeatk = "Ember") ou (nomeatk = "Flamethrower") ou (nomeatk = "Fire Spin") ou (nomeatk = "Fire Blast") entao
         tipoAtkAtual <- "Fire"
      fimse
      se (nomeatk = "Water Gun") ou (nomeatk = "Surf") ou (nomeatk = "Bubble") ou (nomeatk = "Bubble Beam") ou (nomeatk = "Hydro Pump") entao
         tipoAtkAtual <- "Water"
      fimse
      se (nomeatk = "Vine Whip") ou (nomeatk = "Razor Leaf") ou (nomeatk = "Solar Beam") ou (nomeatk = "Absorb") ou (nomeatk = "Sleep Powder") ou (nomeatk = "Stun Spore") entao
         tipoAtkAtual <- "Grass"
      fimse
      se (nomeatk = "Thunder Shock") ou (nomeatk = "Thunderbolt") ou (nomeatk = "Thunder") entao
         tipoAtkAtual <- "Electric"
      fimse
      se (nomeatk = "Rock Throw") ou (nomeatk = "Rock Blast") entao
         tipoAtkAtual <- "Rock"
      fimse
      se (nomeatk = "Earthquake") ou (nomeatk = "Magnitude") ou (nomeatk = "Bone Club") ou (nomeatk = "Bonemerang") ou (nomeatk = "Bone Rush") entao
         tipoAtkAtual <- "Ground"
      fimse
      se (nomeatk = "Gust") ou (nomeatk = "Wing Attack") ou (nomeatk = "Aerial Ace") ou (nomeatk = "Air Slash") entao
         tipoAtkAtual <- "Flying"
      fimse
      se (nomeatk = "Confusion") ou (nomeatk = "Psybeam") ou (nomeatk = "Psychic") ou (nomeatk = "Dream Eater") ou (nomeatk = "Future Sight") entao
         tipoAtkAtual <- "Psychic"
      fimse
      se (nomeatk = "Lick") ou (nomeatk = "Night Shade") ou (nomeatk = "Shadow Ball") entao
         tipoAtkAtual <- "Ghost"
      fimse
      se (nomeatk = "Low Kick") ou (nomeatk = "Karate Chop") ou (nomeatk = "Seismic Toss") ou (nomeatk = "Cross Chop") entao
         tipoAtkAtual <- "Fighting"
      fimse
      se (nomeatk = "Poison Sting") ou (nomeatk = "Acid") ou (nomeatk = "Sludge Bomb") ou (nomeatk = "Poison Powder") entao
         tipoAtkAtual <- "Poison"
      fimse
      se (nomeatk = "Leech Life") ou (nomeatk = "String Shot") ou (nomeatk = "Pin Missile") entao
         tipoAtkAtual <- "Bug"
      fimse
      se (nomeatk = "Ice Beam") ou (nomeatk = "Blizzard") entao
         tipoAtkAtual <- "Ice"
      fimse
      se (nomeatk = "Dragon Claw") ou (nomeatk = "Dragon Rage") entao
         tipoAtkAtual <- "Dragon"
      fimse

      // --- TIPO DO DEFENSOR (INIMIGO) ---
      tipoDefAtual <- "Normal"

      // ERRO 2 CORRIGIDO — Rock/Ground: Ground captura imunidade a Electric
      se (nomeIni[atualIni] = "GEODUDE") ou (nomeIni[atualIni] = "GRAVELER") ou (nomeIni[atualIni] = "ONIX") entao
         tipoDefAtual <- "Ground"
      fimse
      // Ground (mono)
      se (nomeIni[atualIni] = "SANDSHREW") ou (nomeIni[atualIni] = "CUBONE") entao
         tipoDefAtual <- "Ground"
      fimse
      // Water (mono)
      se (nomeIni[atualIni] = "PSYDUCK") ou (nomeIni[atualIni] = "POLIWAG") ou (nomeIni[atualIni] = "MAGIKARP") entao
         tipoDefAtual <- "Water"
      fimse
      // Water/Psychic
      se (nomeIni[atualIni] = "STARMIE") entao
         tipoDefAtual <- "Psychic"
      fimse
      // ERRO 1 CORRIGIDO — Tentacool é Water/Poison, Water é o tipo principal
      se (nomeIni[atualIni] = "TENTACOOL") entao
         tipoDefAtual <- "Water"
      fimse
      // Electric (mono)
      se (nomeIni[atualIni] = "PIKACHU") ou (nomeIni[atualIni] = "RAICHU") entao
         tipoDefAtual <- "Electric"
      fimse
      // ERRO 3 CORRIGIDO — Zubat é Poison/Flying, separado de Pidgey
      se (nomeIni[atualIni] = "ZUBAT") entao
         tipoDefAtual <- "Poison"
      fimse
      // Normal/Flying
      se (nomeIni[atualIni] = "PIDGEY") ou (nomeIni[atualIni] = "PIDGEOTTO") ou (nomeIni[atualIni] = "PIDGEOT") entao
         tipoDefAtual <- "Flying"
      fimse
      // Bug (mono)
      se (nomeIni[atualIni] = "CATERPIE") ou (nomeIni[atualIni] = "PARAS") entao
         tipoDefAtual <- "Bug"
      fimse
      // ERRO 5 CORRIGIDO — Weedle é Bug/Poison, separado de Caterpie/Paras
      se (nomeIni[atualIni] = "WEEDLE") entao
         tipoDefAtual <- "Poison"
      fimse
      // Grass/Poison
      se (nomeIni[atualIni] = "BULBASAUR") ou (nomeIni[atualIni] = "IVYSAUR") ou (nomeIni[atualIni] = "VENUSAUR") entao
         tipoDefAtual <- "Grass"
      fimse
      // ERRO 6 CORRIGIDO — Oddish é Grass/Poison, separado de Bulbasaur
      se (nomeIni[atualIni] = "ODDISH") entao
         tipoDefAtual <- "Poison"
      fimse
      // Fire (mono)
      se (nomeIni[atualIni] = "VULPIX") ou (nomeIni[atualIni] = "GROWLITHE") ou (nomeIni[atualIni] = "CHARMANDER") ou (nomeIni[atualIni] = "CHARMELEON") entao
         tipoDefAtual <- "Fire"
      fimse
      // Fire/Flying — Charizard
      se (nomeIni[atualIni] = "CHARIZARD") entao
         tipoDefAtual <- "Fire"
      fimse
      // Water (mono)
      se (nomeIni[atualIni] = "SQUIRTLE") ou (nomeIni[atualIni] = "WARTORTLE") ou (nomeIni[atualIni] = "BLASTOISE") entao
         tipoDefAtual <- "Water"
      fimse
      // Fighting (mono)
      se (nomeIni[atualIni] = "MACHOP") entao
         tipoDefAtual <- "Fighting"
      fimse
      // Ghost/Poison
      se (nomeIni[atualIni] = "GASTLY") ou (nomeIni[atualIni] = "HAUNTER") entao
         tipoDefAtual <- "Ghost"
      fimse
      // Psychic (mono)
      se (nomeIni[atualIni] = "DROWZEE") ou (nomeIni[atualIni] = "KADABRA") entao
         tipoDefAtual <- "Psychic"
      fimse

      // --- APLICAR MULTIPLICADOR ---
      calcularMultiplicador()
      se multTipo = 4 entao
         dano <- dano * 4
         exibirMensagem(nomeJog[atualJog] + " usou " + nomeatk + "! E extremamente efetivo!")
      fimse
      se multTipo = 2 entao
         dano <- dano * 2
         exibirMensagem(nomeJog[atualJog] + " usou " + nomeatk + "! E super-efetivo!")
      fimse
      se multTipo = 1 entao
         exibirMensagem(nomeJog[atualJog] + " usou " + nomeatk + "!")
      fimse
      se multTipo = 0 entao
         dano <- dano div 2
         exibirMensagem(nomeJog[atualJog] + " usou " + nomeatk + "! Nao e muito efetivo...")
      fimse
      se multTipo = -1 entao
         dano <- dano div 4
         exibirMensagem(nomeJog[atualJog] + " usou " + nomeatk + "! Nao e muito efetivo...")
      fimse
      se multTipo = -2 entao
         dano <- 0
         exibirMensagem(nomeJog[atualJog] + " usou " + nomeatk + "! Nao afeta " + nomeIni[atualIni] + "!")
      fimse

      hpIni[atualIni] <- hpIni[atualIni] - dano
      verificarTimeInimigo()
      se batalhaAtiva entao
         turnoInimigo()
      fimse
   senao
      se atkscolhido <> 0 entao
         exibirMensagem("Ataque invalido!")
      fimse
   fimse
fimprocedimento

// ============================================================
//  EXECUTAR MOCHILA
// ============================================================
procedimento executarMochila()
var
   itemEscolhido : inteiro
inicio
   menuMochila()
   leia(itemEscolhido)
   escolha itemEscolhido
   caso 1
      se qtdPotion > 0 entao
         qtdPotion <- qtdPotion - 1
         cura <- 30
         se (hpJog[atualJog] + cura) > hpMaxJog[atualJog] entao
            cura <- hpMaxJog[atualJog] - hpJog[atualJog]
         fimse
         hpJog[atualJog] <- hpJog[atualJog] + cura
         exibirMensagem(nomeJog[atualJog] + " recuperou 30 HP!")
         turnoInimigo()
      senao
         exibirMensagem("Sem Potions!")
      fimse
   caso 2
      se qtdSuperPotion > 0 entao
         qtdSuperPotion <- qtdSuperPotion - 1
         cura <- 60
         se (hpJog[atualJog] + cura) > hpMaxJog[atualJog] entao
            cura <- hpMaxJog[atualJog] - hpJog[atualJog]
         fimse
         hpJog[atualJog] <- hpJog[atualJog] + cura
         exibirMensagem(nomeJog[atualJog] + " recuperou 60 HP!")
         turnoInimigo()
      senao
         exibirMensagem("Sem Super Potions!")
      fimse
   caso 0
   outrocaso
      exibirMensagem("Item invalido!")
   fimescolha
fimprocedimento

// ============================================================
//  EXECUTAR TROCA DE POKEMON
// ============================================================
procedimento executarPokemon()
var
   escolher : inteiro
inicio
   menuPokemon()
   leia(escolher)
   se (escolher >= 1) e (escolher <= tamTime) entao
      se escolher = atualJog entao
         exibirMensagem(nomeJog[escolher] + " ja esta em campo!")
      senao
         se ativoJog[escolher] entao
            exibirMensagem(nomeJog[atualJog] + " voltou!")
            atualJog <- escolher
            exibirMensagem("VAI, " + nomeJog[atualJog] + "!")
            turnoInimigo()
         senao
            exibirMensagem("Esse Pokemon desmaiou!")
         fimse
      fimse
   fimse
fimprocedimento

// ============================================================
//  TENTAR CAPTURA (pokebola)
// ============================================================
procedimento tentarCaptura()
inicio
   se tamTime >= 6 entao
   exibirMensagem("Seu time esta cheio! Nao pode capturar mais Pokemon.")
senao
   se hpIni[atualIni] > (hpMaxIni[atualIni] div 2) entao
      exibirMensagem("O Pokemon ainda esta com muita energia! Enfraqueça o primeiro.")
      turnoInimigo()
   senao
         tentCaptura <- tentCaptura + 1
          limpatela
            timer(20)
