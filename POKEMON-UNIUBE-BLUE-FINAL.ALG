// ============================================================
//  VERIFICAR EVOLUCAO DO STARTER
//  Chamado apos cada batalha selvagem.
//  A cada 2 batalhas selvagens o starter evolui.
// ============================================================
procedimento verificarEvolucao()
inicio
   batalhasSelvagens <- batalhasSelvagens + 1

   se (batalhasSelvagens = 2) e (starterEvoluido = 0) entao
      starterEvoluido <- 1
      limpatela
      escreval("=============================================================================================================================================================================================")
      escreval("  Algo esta acontecendo com seu Pokemon!")
      escreval("=============================================================================================================================================================================================")
      escreval("")
      // [ASCII-EVOLUCAO-1] Cole aqui a arte da primeira evolucao
      se starterIdx = 1 entao
         escreval("  BULBASAUR esta evoluindo!")
